<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Reset your Auditarr password</title>
  </head>
  <body style="margin:0;padding:0;background:#f7f7f5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;color:#0e0e10;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="padding:32px 0;">
      <tr>
        <td align="center">
          <table role="presentation" width="560" cellpadding="0" cellspacing="0" style="background:#ffffff;border:1px solid #e6e6e3;border-radius:8px;padding:32px;">
            <tr><td style="font-size:18px;font-weight:600;letter-spacing:-0.01em;">Reset your Auditarr password</td></tr>
            <tr><td style="height:16px;"></td></tr>
            <tr><td style="font-size:14px;line-height:1.55;color:#3a3a3d;">
              Hi {{ name }},<br /><br />
              Someone requested a password reset for your Auditarr account. If that was you,
              click the button below within 30 minutes to set a new password.
            </td></tr>
            <tr><td style="height:24px;"></td></tr>
            <tr><td>
              <a href="{{ link }}"
                 style="display:inline-block;padding:10px 18px;background:#0e0e10;color:#ffffff;text-decoration:none;border-radius:6px;font-size:13px;font-weight:600;">
                Reset password
              </a>
            </td></tr>
            <tr><td style="height:16px;"></td></tr>
            <tr><td style="font-size:12px;color:#74747a;line-height:1.5;">
              Or paste this URL into your browser:<br />
              <span style="font-family:ui-monospace,Menlo,Consolas,monospace;color:#3a3a3d;">{{ link }}</span>
            </td></tr>
            <tr><td style="height:24px;"></td></tr>
            <tr><td style="font-size:12px;color:#74747a;border-top:1px solid #e6e6e3;padding-top:16px;">
              If you did not request this, you can safely ignore this email — your password will remain unchanged.<br /><br />
              — {{ from_name }}
            </td></tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
