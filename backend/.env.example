# Auditarr backend — environment configuration
# Copy to .env for local development.

# ── App ─────────────────────────────────────────────────────────
AUDITARR_ENV=development
AUDITARR_DEBUG=true
AUDITARR_HOST=0.0.0.0
AUDITARR_PORT=8000
AUDITARR_LOG_LEVEL=info
AUDITARR_LOG_FORMAT=console

# ── Security ────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
AUDITARR_SECRET_KEY=change-me-in-production-this-is-a-development-default-key
AUDITARR_JWT_ALGORITHM=HS256
AUDITARR_ACCESS_TOKEN_TTL_MINUTES=30
AUDITARR_REFRESH_TOKEN_TTL_DAYS=14
AUDITARR_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Database ────────────────────────────────────────────────────
# Stage 1 default: Postgres (matches production).
AUDITARR_DATABASE_URL=postgresql+asyncpg://auditarr:auditarr@localhost:5432/auditarr
# To run with SQLite (testing only), uncomment:
# AUDITARR_DATABASE_URL=sqlite+aiosqlite:///./auditarr.db

# ── Redis / queue ───────────────────────────────────────────────
AUDITARR_REDIS_URL=redis://localhost:6379/0
AUDITARR_QUEUE_NAME=auditarr:queue

# ── Plugins / data dirs ─────────────────────────────────────────
AUDITARR_DATA_DIR=./data
AUDITARR_PLUGIN_DIR=./plugins
AUDITARR_DOCS_DIR=./docs

# ── Frontend ────────────────────────────────────────────────────
# When set, FastAPI will serve the built SPA from this directory.
AUDITARR_FRONTEND_DIST=
