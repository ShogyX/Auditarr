# Auditarr — Docker Compose environment.
# Copy to .env before running `docker compose up`.

# ── App ─────────────────────────────────────────────────────────
AUDITARR_ENV=production
AUDITARR_PORT=8000
AUDITARR_LOG_LEVEL=info
AUDITARR_LOG_FORMAT=json

# Generate a strong secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
AUDITARR_SECRET_KEY=replace-with-strong-random-value-at-least-sixteen-chars

# ── Postgres ────────────────────────────────────────────────────
POSTGRES_DB=auditarr
POSTGRES_USER=auditarr
POSTGRES_PASSWORD=replace-with-strong-database-password

# ── First-boot admin (only effective when no users exist) ──────
# Leave blank to skip; password must be at least 12 characters.
AUDITARR_BOOTSTRAP_ADMIN_USERNAME=
AUDITARR_BOOTSTRAP_ADMIN_PASSWORD=
AUDITARR_BOOTSTRAP_ADMIN_EMAIL=

# ── SMTP (optional — leave AUDITARR_SMTP_ENABLED=false to log instead of send)
AUDITARR_SMTP_ENABLED=false
AUDITARR_SMTP_BACKEND=console
AUDITARR_SMTP_HOST=localhost
AUDITARR_SMTP_PORT=25
AUDITARR_SMTP_USERNAME=
AUDITARR_SMTP_PASSWORD=
AUDITARR_SMTP_USE_TLS=false
AUDITARR_SMTP_USE_SSL=false
AUDITARR_SMTP_FROM_EMAIL=noreply@example.com
AUDITARR_SMTP_FROM_NAME=Auditarr
AUDITARR_SMTP_RESET_LINK_BASE=http://localhost:8000
